/* Tetra Video CSS */
.header-unit {
    height: 500px;
    position: relative;
}
#video-container {
    position: absolute;
}
#video-container {
    top:0%;
    left:0%;
    height:100%;
    width:100%;
    overflow: hidden;
}
video {
    position:absolute;
}

video.fillWidth {
    height: 120%;
}


/* Vero */
@media only screen and (max-width: 1025px) {
.fl-builder-content .vero-top-bar > .fl-row-content-wrap  {
	background-image: none;
}
}

