    position:relative;
}

/* Remove Photo on IPad and Mobile */ 
@media only screen and (max-width: 768px) { 
.bg-color-ipadmobile .fl-row-content-wrap{background-image:none;} 
}

/* Initially Hide Scrolling Row */ 
#scroll-row {
    display: none;
