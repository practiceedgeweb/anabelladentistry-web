    <script>
    document.addEventListener('DOMContentLoaded', function () {
        var posts = document.querySelectorAll('.fl-post-grid-post');
        if (!posts.length) return;

        posts.forEach(function (post) {
            var titleEl = post.querySelector('.fl-post-grid-title a');
            var contentP = post.querySelector('.fl-post-grid-content > p');

            if (!titleEl || !contentP) return;

            var titleText = titleEl.textContent.trim();
            var paraText  = contentP.textContent.trim();

            // If the paragraph starts with the title, remove it
            if (paraText.indexOf(titleText) === 0) {
                var newText = paraText.substring(titleText.length).trim();
                contentP.textContent = newText;
            }
        });
    });
    </script>
    </body>
