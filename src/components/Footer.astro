---
import site from '../data/site.json';
const { contact, hours } = site;
const allDays = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

const PLACE_ID = 'ChIJGWCelPJskFQRPyUauOk4Iac';
const PLACES_KEY = process.env.GOOGLE_PLACES_API_KEY ?? import.meta.env.GOOGLE_PLACES_API_KEY;

let reviewRating: number = contact.googleReview.rating;
let reviewCount: number = contact.googleReview.count;

if (PLACES_KEY) {
  try {
    const res = await fetch(
      `https://maps.googleapis.com/maps/api/place/details/json?place_id=${PLACE_ID}&fields=rating,user_ratings_total&key=${PLACES_KEY}`
    );
    const data = await res.json();
    if (data.result?.rating) {
      reviewRating = data.result.rating;
      reviewCount = data.result.user_ratings_total;
    }
  } catch {
    // use fallback
  }
}

const fullStars = Math.floor(reviewRating);
const hasHalf = reviewRating - fullStars >= 0.5;
const reviewUrl = contact.googleReview.url;

const finalCta = {
  prefix: 'Ready to find out more?',
  title: 'New Patient Special Offer',
  href: '/special/',
};
---

<!-- ── Final CTA ── -->
<section class="final-cta">
  <div class="container cta-inner">
    <div class="cta-text">
      <p class="cta-prefix">{finalCta.prefix}</p>
      <h2>{finalCta.title}</h2>
    </div>
    <a href={finalCta.href} class="btn-cta-circle">
      <span class="cta-circle-inner">REQUEST AN<br />APPOINTMENT</span>
    </a>
  </div>
</section>

<!-- ── Contact ── -->
<section id="contact" class="contact-section">
  <div class="contact-grid">
    <div class="contact-map">
      <iframe
        title="Map of AnaBella Family and Cosmetic Dentistry"
        src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d5378.169584659924!2d-122.19014100000001!3d47.624483!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x54906cf2949e6019%3A0xa72138e9b81a253f!2sAnaBella%20Family%20and%20Cosmetic%20Dentistry!5e0!3m2!1sen!2sus!4v1760463607075!5m2!1sen!2sus"
        loading="lazy"
        width="100%"
        height="100%"
        style="border:0; min-height:400px;"
        allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

    <div class="contact-info">
      <div class="trusted-badge">
        <svg viewBox="0 0 80 80" width="80" height="80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="40" cy="40" r="38" fill="none" stroke="var(--color-accent-hover)" stroke-width="2"/>
          <circle cx="40" cy="40" r="32" fill="none" stroke="var(--color-accent)" stroke-width="1"/>
          <text x="40" y="30" text-anchor="middle" font-family="Raleway,sans-serif" font-size="7" font-weight="700" fill="var(--color-accent-hover)" letter-spacing="2">TRUSTED</text>
          <text x="40" y="42" text-anchor="middle" font-family="Raleway,sans-serif" font-size="7" font-weight="700" fill="var(--color-accent-hover)" letter-spacing="2">DENTIST</text>
          <text x="40" y="54" text-anchor="middle" font-family="Raleway,sans-serif" font-size="6" fill="var(--color-text-muted)" letter-spacing="1">BELLEVUE WA</text>
        </svg>
      </div>
      <h2>{site.businessName}</h2>
      <address>
        {contact.address.street}<br />
        {contact.address.city}, {contact.address.state} {contact.address.zip}
      </address>

      <a href={reviewUrl} class="review-row" target="_blank" rel="noopener noreferrer" aria-label={`${reviewRating} out of 5 stars — ${reviewCount} Google reviews`}>
        <span class="review-stars" aria-hidden="true">
          {Array.from({ length: fullStars }).map(() => (
            <svg viewBox="0 0 20 20" width="16" height="16" fill="#f5a623"><polygon points="10,1 12.9,7 19.5,7.6 14.5,12 16.2,18.5 10,15 3.8,18.5 5.5,12 0.5,7.6 7.1,7"/></svg>
          ))}
          {hasHalf && (
            <svg viewBox="0 0 20 20" width="16" height="16"><defs><linearGradient id="half-f"><stop offset="50%" stop-color="#f5a623"/><stop offset="50%" stop-color="#ddd"/></linearGradient></defs><polygon points="10,1 12.9,7 19.5,7.6 14.5,12 16.2,18.5 10,15 3.8,18.5 5.5,12 0.5,7.6 7.1,7" fill="url(#half-f)"/></svg>
          )}
          {Array.from({ length: 5 - fullStars - (hasHalf ? 1 : 0) }).map(() => (
            <svg viewBox="0 0 20 20" width="16" height="16" fill="#ddd"><polygon points="10,1 12.9,7 19.5,7.6 14.5,12 16.2,18.5 10,15 3.8,18.5 5.5,12 0.5,7.6 7.1,7"/></svg>
          ))}
        </span>
        <span class="review-meta">
          <strong>{reviewRating}</strong> · {reviewCount} Google reviews
        </span>
      </a>

      <a href={`tel:${contact.phoneTel}`} class="contact-phone">{contact.phone}</a>
      <div class="contact-actions">
        <a href={site.zocDocUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">Book Online</a>
        <a href="/contact-us/" class="btn-outline-contact">Contact Us</a>
      </div>
    </div>

    <div class="contact-hours">
      <h3>Office Hours</h3>
      <ul class="hours-list">
        {allDays.map((d) => (
          <li class={hours[d] === 'Closed' ? 'closed' : ''}>
            <span class="day">{d}</span>
            <span class="time">{hours[d]}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<!-- ── Dark footer bar ── -->
<footer class="site-footer">
  <div class="footer-main">
    <div class="container footer-inner">
      <div class="col">
        <strong>{site.businessName}</strong>
        <p>
          {contact.address.street}<br />
          {contact.address.city}, {contact.address.state} {contact.address.zip}
        </p>
        <p><a href={`tel:${contact.phoneTel}`}>{contact.phone}</a></p>
      </div>
      <div class="col">
        <strong>Policies</strong>
        <ul>
          {site.footer.links.map((l) => (
            <li><a href={l.href}>{l.text}</a></li>
          ))}
        </ul>
      </div>
      <div class="col">
        <strong>Visit Us</strong>
        <ul>
          <li><a href="/schedule/">Schedule an Appointment</a></li>
          <li><a href="/dental-insurance-accepted/">Insurance</a></li>
          <li><a href="/contact-us/">Contact</a></li>
          <li><a href="/review-us/">Review Us</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>COPYRIGHT &copy; {new Date().getFullYear()} {site.businessName}. All rights reserved.</p>
      <nav class="footer-policy-nav" aria-label="Legal">
        {site.footer.links.slice(0, 4).map((l) => (
          <a href={l.href}>{l.text}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  /* ── Final CTA ── */
  .final-cta {
    background: var(--color-accent);
    padding: 4rem 0;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .cta-text { flex: 1; }
  .cta-prefix {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-text-main);
    margin-bottom: 0.75rem;
    font-weight: 700;
    display: block;
  }
  .cta-text h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-main);
  }
  .btn-cta-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: #e07b20;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }
  .btn-cta-circle:hover { background: #c56a10; transform: scale(1.04); }
  .cta-circle-inner {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #333333;
    text-align: center;
    line-height: 1.5;
  }

  /* ── Contact ── */
  .contact-section { background: #fff; padding: 0; }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    max-width: var(--container-width);
    margin: 0 auto;
    min-height: 420px;
  }
  .contact-map { overflow: hidden; }
  .contact-map iframe { display: block; width: 100%; height: 100%; min-height: 420px; }

  .contact-info {
    padding: 3rem 2.5rem;
    background: var(--color-accent-wave);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    justify-content: center;
  }
  .trusted-badge { margin-bottom: 0.5rem; }
  .contact-info h2 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.3;
  }
  address {
    font-style: normal;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }
  .review-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    margin-top: 0.1rem;
  }
  .review-row:hover .review-meta { color: var(--color-accent-hover); }
  .review-stars { display: flex; align-items: center; gap: 1px; }
  .review-meta { font-size: 0.82rem; color: var(--color-text-muted); transition: color 0.2s; }
  .review-meta strong { color: var(--color-text-main); font-weight: 700; }

  .contact-phone {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-main);
    display: block;
    margin-top: 0.25rem;
  }
  .contact-phone:hover { color: var(--color-accent-hover); }
  .contact-actions { display: flex; flex-direction: column; gap: 0.6rem; align-items: flex-start; margin-top: 0.5rem; }
  .btn-outline-contact {
    display: inline-block;
    border: 2px solid var(--color-text-main);
    color: var(--color-text-main);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.65rem 1.4rem;
    border-radius: 4px;
    transition: background 0.2s, color 0.2s;
  }
  .btn-outline-contact:hover { background: var(--color-text-main); color: #fff; }

  .contact-hours {
    padding: 3rem 2.5rem;
    background: #fff;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .contact-hours h3 {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-main);
    margin-bottom: 1.25rem;
  }
  .hours-list { list-style: none; }
  .hours-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9rem;
  }
  .hours-list li.closed { color: var(--color-text-muted); }
  .day { font-weight: 600; color: var(--color-text-main); }
  .time { color: var(--color-text-muted); }

  /* ── Dark footer bar ── */
  .site-footer { background: var(--color-header-bg); color: var(--color-header-text); }
  .footer-main { padding: 3rem 0; }
  .footer-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }
  .col strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .col p { font-size: 0.9rem; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 0.5rem; }
  .col a { color: rgba(255,255,255,0.75); font-size: 0.9rem; transition: color 0.15s; }
  .col a:hover { color: var(--color-accent); }
  .col ul { list-style: none; }
  .col li { margin-bottom: 0.4rem; }

  .footer-bottom {
    background: var(--color-accent);
    padding: 1rem 0;
  }
  .footer-bottom .container {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .footer-bottom p {
    font-size: 0.75rem;
    color: var(--color-text-main);
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .footer-policy-nav { display: flex; flex-wrap: wrap; gap: 1rem; }
  .footer-policy-nav a {
    font-size: 0.7rem;
    color: var(--color-text-main);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .footer-policy-nav a:hover { color: var(--color-accent-hover); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-map iframe { min-height: 280px; }
    .cta-inner { flex-direction: column; align-items: center; text-align: center; }
    .cta-text { text-align: center; }
  }
  @media (max-width: 700px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-bottom .container { flex-direction: column; align-items: flex-start; }
  }
</style>
