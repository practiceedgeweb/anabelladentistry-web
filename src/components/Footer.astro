---
import site from '../data/site.json';
---
<footer class="site-footer">
  <div class="footer-main">
    <div class="container footer-inner">
      <div class="col">
        <strong>{site.businessName}</strong>
        <p>
          {site.contact.address.street}<br />
          {site.contact.address.city}, {site.contact.address.state} {site.contact.address.zip}
        </p>
        <p><a href={`tel:${site.contact.phoneTel}`}>{site.contact.phone}</a></p>
      </div>
      <div class="col">
        <strong>Policies</strong>
        <ul>
          {site.footer.links.map((l) => (
            <li><a href={l.href}>{l.text}</a></li>
          ))}
        </ul>
      </div>
      <div class="col">
        <strong>Visit Us</strong>
        <ul>
          <li><a href="/schedule/">Schedule an Appointment</a></li>
          <li><a href="/dental-insurance-accepted/">Insurance</a></li>
          <li><a href="/contact-us/">Contact</a></li>
          <li><a href="/review-us/">Review Us</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>COPYRIGHT © {new Date().getFullYear()} {site.businessName}. All rights reserved.</p>
      <nav class="footer-policy-nav" aria-label="Legal">
        {site.footer.links.slice(0, 4).map((l) => (
          <a href={l.href}>{l.text}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-header-bg);
    color: var(--color-header-text);
  }

  .footer-main { padding: 3rem 0; }
  .footer-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }
  .col strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .col p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }
  .col a {
    color: rgba(255,255,255,0.75);
    font-size: 0.9rem;
    transition: color 0.15s;
  }
  .col a:hover { color: var(--color-accent); }
  .col ul { list-style: none; }
  .col li { margin-bottom: 0.4rem; }

  .footer-bottom {
    background: var(--color-accent);
    padding: 1rem 0;
  }
  .footer-bottom .container {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .footer-bottom p {
    font-size: 0.75rem;
    color: var(--color-text-main);
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .footer-policy-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-policy-nav a {
    font-size: 0.7rem;
    color: var(--color-text-main);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.8;
    transition: opacity 0.15s;
  }
  .footer-policy-nav a:hover { opacity: 1; }

  @media (max-width: 700px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-bottom .container { flex-direction: column; align-items: flex-start; }
  }
</style>
