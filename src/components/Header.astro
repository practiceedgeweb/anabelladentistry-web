          </li>
          <li class="has-submenu">
            <a href="#patients">Patients</a>
            <ul class="submenu">
              <li><a href="/patient-info/schedule-appointment/">Schedule Appointment</a></li>
              <li><a href="/patient-info/insurance/">Insurance</a></li>
              <li><a href="/patient-info/">Patient Information</a></li>
              <li class="has-inner-submenu">
                <a href="#">FAQs & Information</a>
                <ul class="inner-submenu">
                  <li><a href="/implant-benefits/">Implant Benefits</a></li>
                  <li><a href="/dentures-care/">Dentures Care</a></li>
                  <li><a href="/brushing-guide/">How to Brush</a></li>
