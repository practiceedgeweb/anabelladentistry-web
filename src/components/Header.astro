</header>

<style>
  .header {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--color-header-bg);
    box-shadow: 0 2px 15px rgba(0,0,0,0.2);
  }

  /* Header Top Bar */
  .header-top {
    background: var(--color-topbar-bg);
    padding: 0.5rem 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: white;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .top-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .top-btn {
    background: var(--color-gold);
    color: white;
    padding: 4px 12px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.7rem;
  }

  /* Main Header */
  .header-main {
    padding: 0.75rem 0;
  }
  .main-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo img {
    height: 65px;
    width: auto;
    filter: brightness(0) invert(1); /* Makes the logo white for the dark header */
  }

  /* Navigation & Menus */
  .menu {
    display: flex;
    list-style: none;
    gap: 1rem;
    align-items: center;
  }
  .menu > li > a {
    text-decoration: none;
    color: var(--color-nav-link);
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1.5rem 0.5rem;
    transition: color 0.2s ease;
  }
  .menu li:hover > a {
    color: var(--color-nav-hover);
  }

  /* Dropdowns */
  .has-submenu {
    position: relative;
  }
  .submenu {
    position: absolute;
    top: 100%;
    left: 0;
    background: white;
    width: 240px;
    list-style: none;
    padding: 1rem 0;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    border-top: 3px solid var(--color-gold);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s ease;
  }
  .has-submenu:hover > .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .submenu li a {
    display: block;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    color: var(--color-text-main);
    font-size: 0.8125rem;
    font-weight: 600;
  }
  .submenu li a:hover {
    background: #f9f7f2;
    color: var(--color-gold);
  }
  
  @media (max-width: 900px) {
    .nav { display: none; }
  }
</style>
