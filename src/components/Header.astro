---
import site from '../data/site.json';
---
<header class="site-header">
  <div class="top-bar">
    <div class="container top-inner">
      <a href={`tel:${site.contact.phoneTel}`} class="phone">{site.contact.phone}</a>
      <div class="top-actions">
        <a href="/accessibility/">Accessibility</a>
        <a href="/hipaa-privacy-policy/">HIPAA Policy</a>
        <a href="/special/" class="top-btn">New Patient Special</a>
      </div>
    </div>
  </div>
  <div class="header-main">
    <div class="container main-inner">
      <a href="/" class="logo" aria-label="AnaBella Family and Cosmetic Dentistry home">
        <img
          src="/assets/2025/10/Dentist-Bellevue-WA-AnaBella-Family-and-Cosmetic-Dentistry-Header-Logo.webp"
          onerror="this.onerror=null;this.src='https://www.anabelladentistry.com/wp-content/uploads/2025/10/Dentist-Bellevue-WA-AnaBella-Family-and-Cosmetic-Dentistry-Header-Logo.webp';"
          alt="AnaBella Family and Cosmetic Dentistry"
          width="250"
          height="130"
        />
      </a>
      <nav class="nav" aria-label="Primary">
        <ul class="menu">
          {site.nav.map((item) => (
            <li class={item.children ? 'has-submenu' : ''}>
              <a href={item.href}>{item.text}</a>
              {item.children && (
                <ul class="submenu">
                  {item.children.map((child) => (
                    <li><a href={child.href}>{child.text}</a></li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </nav>
      <button class="menu-toggle" aria-label="Open menu">☰</button>
    </div>
  </div>
</header>

<style>
  .site-header {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
  }

  .top-bar {
    background: var(--color-header-bg);
    color: var(--color-header-text);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.5rem 0;
  }
  .top-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .phone { color: var(--color-header-text); letter-spacing: 0.04em; }
  .top-actions { display: flex; gap: 1.25rem; align-items: center; }
  .top-actions a { color: var(--color-header-text); text-decoration: none; }
  .top-actions a:hover { color: var(--color-accent-hover); }
  .top-btn {
    background: var(--color-accent-hover);
    color: #fff !important;
    padding: 4px 12px;
    border-radius: 4px;
  }

  .header-main { padding: 1rem 0; border-bottom: 1px solid var(--color-border); }
  .main-inner { display: flex; justify-content: space-between; align-items: center; gap: 2rem; }
  .logo img { height: 65px; width: auto; display: block; }

  .menu {
    display: flex;
    list-style: none;
    gap: 1.25rem;
    align-items: center;
  }
  .menu > li > a {
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-main);
    padding: 1rem 0;
    transition: color 0.2s ease;
  }
  .menu > li > a:hover { color: var(--color-accent-hover); }

  .has-submenu { position: relative; }
  .submenu {
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    min-width: 220px;
    list-style: none;
    padding: 0.5rem 0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    border-top: 3px solid var(--color-accent-hover);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: all 0.2s ease;
  }
  .has-submenu:hover > .submenu,
  .has-submenu:focus-within > .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .submenu li a {
    display: block;
    padding: 0.6rem 1.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-main);
  }
  .submenu li a:hover {
    background: var(--color-bg-warm);
    color: var(--color-accent-hover);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
  }

  @media (max-width: 900px) {
    .nav { display: none; }
    .menu-toggle { display: inline-block; }
  }
</style>
