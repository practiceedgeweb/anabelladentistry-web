---
import site from '../data/site.json';
const { contact, nav, zocDocUrl } = site;
---
<header class="site-header">
  <div class="header-top">
    <div class="container top-inner">
      <a href="/" class="logo" aria-label="AnaBella Family and Cosmetic Dentistry home">
        <img
          src="/assets/2025/10/Dentist-Bellevue-WA-AnaBella-Family-and-Cosmetic-Dentistry-Header-Logo.webp"
          onerror="this.onerror=null;this.src='https://www.anabelladentistry.com/wp-content/uploads/2025/10/Dentist-Bellevue-WA-AnaBella-Family-and-Cosmetic-Dentistry-Header-Logo.webp';"
          alt="AnaBella Family and Cosmetic Dentistry"
          width="220"
          height="115"
        />
      </a>
      <div class="top-contact">
        <div class="social-icons">
        <a href="https://www.facebook.com/anabelladentistry" class="social-icon" target="_blank" rel="noopener noreferrer" aria-label="AnaBella on Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36" aria-hidden="true">
            <circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.15)"/>
            <path d="M15.1 8.3h-1.6c-.4 0-.5.2-.5.6v1.1h2.1l-.3 2.2h-1.8V18h-2.3v-5.8H9.5V10h1.2V8.7c0-1.7.9-2.7 2.8-2.7h1.6v2.3z" fill="#fff"/>
          </svg>
        </a>
        <a href="https://www.instagram.com/anabelladentistry/" class="social-icon" target="_blank" rel="noopener noreferrer" aria-label="AnaBella on Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="36" height="36" aria-hidden="true">
            <circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.15)"/>
            <rect x="7" y="7" width="10" height="10" rx="3" ry="3" fill="none" stroke="#fff" stroke-width="1.5"/>
            <circle cx="12" cy="12" r="2.5" fill="none" stroke="#fff" stroke-width="1.5"/>
            <circle cx="15.2" cy="8.8" r="0.8" fill="#fff"/>
          </svg>
        </a>
        </div>
        <div>
          <p class="top-address">{contact.address.street} | {contact.address.city} {contact.address.state} {contact.address.zip}</p>
          <a href={`tel:${contact.phoneTel}`} class="top-phone">{contact.phone}</a>
        </div>
      </div>
      <a href={zocDocUrl} class="btn-schedule" target="_blank" rel="noopener noreferrer">Schedule Online</a>
    </div>
  </div>

  <nav class="header-nav" aria-label="Primary">
    <div class="container nav-inner">
      <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" />
      <label for="nav-toggle" class="hamburger" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </label>
      <ul class="menu">
        {nav.map((item) => (
          <li class={item.children && item.children.length > 0 ? 'has-drop' : ''}>
            <a href={item.href}>{item.text}</a>
            {item.children && item.children.length > 0 && (
              <ul class="dropdown">
                {item.children.map((child) => (
                  <li class={child.children && child.children.length > 0 ? 'has-fly' : ''}>
                    <a href={child.href}>{child.text}</a>
                    {child.children && child.children.length > 0 && (
                      <ul class="flyout">
                        {child.children.map((grandchild) => (
                          <li><a href={grandchild.href}>{grandchild.text}</a></li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  .site-header {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-accent);
  }

  /* ── Top row: logo | contact | schedule ── */
  .header-top { border-bottom: 1px solid rgba(0,0,0,0.08); }
  .top-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.75rem 0;
  }
  .logo img { height: 70px; width: auto; display: block; }

  .top-contact { display: flex; align-items: center; gap: 1rem; text-align: center; }
  .social-icons { display: flex; gap: 0.4rem; }
  .social-icon { display: flex; align-items: center; opacity: 0.9; transition: opacity 0.2s; }
  .social-icon:hover { opacity: 1; }
  .top-address {
    font-size: 0.82rem;
    color: var(--color-text-main);
    margin-bottom: 0.25rem;
  }
  .top-phone {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-main);
    letter-spacing: 0.02em;
  }
  .top-phone:hover { color: var(--color-accent-hover); }

  .btn-schedule {
    background: var(--color-accent-hover);
    color: #333333;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.7rem 1.4rem;
    border: 2px solid var(--color-accent-hover);
    white-space: nowrap;
    transition: background 0.2s, color 0.2s;
  }
  .btn-schedule:hover { background: transparent; color: var(--color-text-main); }

  /* ── Nav row ── */
  .header-nav { background: var(--color-accent); }
  .nav-inner { display: flex; align-items: center; }

  .menu {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0;
  }
  .menu > li > a {
    display: block;
    padding: 0.85rem 1.1rem;
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-main);
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .menu > li:hover > a,
  .menu > li > a:hover {
    background: rgba(0,0,0,0.08);
    color: var(--color-accent-hover);
  }

  /* ── Dropdown ── */
  .has-drop { position: relative; }
  .dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--color-accent);
    min-width: 200px;
    list-style: none;
    padding: 0.4rem 0;
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    border-top: 2px solid var(--color-accent-hover);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 0.18s, transform 0.18s, visibility 0.18s;
  }
  .has-drop:hover > .dropdown,
  .has-drop:focus-within > .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown li a {
    display: block;
    padding: 0.55rem 1.1rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-main);
    white-space: nowrap;
  }
  .dropdown li a:hover { background: rgba(0,0,0,0.08); color: var(--color-accent-hover); }

  /* ── Third-level fly-out ── */
  .has-fly { position: relative; }
  .has-fly > a::after { content: ' ›'; opacity: 0.6; }
  .flyout {
    position: absolute;
    top: 0;
    left: 100%;
    background: var(--color-accent);
    min-width: 220px;
    list-style: none;
    padding: 0.4rem 0;
    box-shadow: 6px 6px 20px rgba(0,0,0,0.12);
    border-top: 2px solid var(--color-accent-hover);
    opacity: 0;
    visibility: hidden;
    transform: translateX(4px);
    transition: opacity 0.18s, transform 0.18s, visibility 0.18s;
  }
  .has-fly:hover > .flyout,
  .has-fly:focus-within > .flyout {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
  }
  .flyout li a {
    display: block;
    padding: 0.55rem 1.1rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-main);
    white-space: nowrap;
  }
  .flyout li a:hover { background: rgba(0,0,0,0.08); color: var(--color-accent-hover); }

  /* ── Mobile hamburger ── */
  .nav-toggle-input { display: none; }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text-main);
    transition: transform 0.2s, opacity 0.2s;
  }
  .nav-toggle-input:checked + .hamburger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle-input:checked + .hamburger span:nth-child(2) { opacity: 0; }
  .nav-toggle-input:checked + .hamburger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 900px) {
    .top-inner { flex-wrap: wrap; }
    .hamburger { display: flex; }
    .menu {
      display: none;
      flex-direction: column;
      width: 100%;
      background: var(--color-accent);
    }
    .nav-toggle-input:checked + .hamburger + .menu { display: flex; }
    .dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border-top: none;
      padding-left: 1rem;
    }
    .has-drop:hover > .dropdown { display: block; }
    .flyout {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border-top: none;
      padding-left: 1rem;
    }
    .has-fly > a::after { content: ''; }
  }
</style>
