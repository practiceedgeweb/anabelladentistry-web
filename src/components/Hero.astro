---
import home from '../data/pages/home.json';
const hero = home.hero;
---
<section class="hero">
  <div class="hero-bg">
    <img
      src="/assets/2025/10/Dentist-Bellevue-WA-AnaBella-Family-and-Cosmetic-Dentistry-Header-Logo.webp"
      onerror="this.style.display='none'"
      alt=""
      aria-hidden="true"
      class="bg-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content">
    <p class="hero-sub">{hero.h1}</p>
    <h1>{hero.tagline}</h1>
    <a href={hero.primaryCta.href} class="btn-special">{hero.primaryCta.text}</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #3a6b6e;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(40, 80, 85, 0.55);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 4rem 2rem;
    color: #fff;
  }
  .hero-sub {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin-bottom: 1rem;
  }
  .hero-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 2rem;
    text-shadow: 0 2px 12px rgba(0,0,0,0.25);
  }

  .btn-special {
    display: inline-block;
    background: #e8a020;
    color: #333333;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.9rem 2.2rem;
    border-radius: 4px;
    transition: background 0.2s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  .btn-special:hover { background: #c98a10; }

  @media (max-width: 600px) {
    .hero { min-height: 320px; }
  }
</style>
