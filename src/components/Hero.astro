<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <h1>Where Healthy Smiles Begin</h1>
      <p>Our outstanding team is here to help you achieve your smile goals. Contact us today.</p>
      <div class="hero-actions">
        <a href="#" class="btn-gold">New Patient Special</a>
        <a href="#" class="btn-outline">Meet The Dentist</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    height: 90vh;
    background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.05)), url('http://www.dental.inceptionimages.com/wp-content/uploads/2017/01/smiling-woman-2000x1100.jpg') no-repeat center center;
    background-size: cover;
    display: flex;
    align-items: center;
    color: white;
    margin-top: -1px;
  }
  .hero-inner {
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hero-content {
    max-width: 700px;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    padding: 4rem;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.2);
  }
  h1 {
    font-size: 4.5rem;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: white;
  }
  p {
    font-size: 1.25rem;
    color: white;
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-start;
  }
  .btn-outline {
    display: inline-block;
    border: 2px solid white;
    color: white;
    padding: 1rem 2rem;
    border-radius: 4px;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .btn-outline:hover {
    background: white;
    color: var(--color-text-main);
  }
  
  @media (max-width: 768px) {
    h1 { font-size: 3rem; }
    p { font-size: 1.125rem; }
    .hero-actions { flex-direction: column; width: 100%; }
  }
</style>
