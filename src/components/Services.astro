---
import home from '../data/pages/home.json';
const services = home.services;
const sleepApnea = home.sleepApnea;
---
<section id="services" class="services-section">
  <div class="services-wrap">
    <!-- 2×2 image overlay grid -->
    <div class="services-grid">
      {services.map((s) => (
        <a class="service-tile" href={s.href}>
          <img
            src={`/assets/2025/10/${s.image.split('/').pop()}`}
            onerror={`this.onerror=null;this.src='${s.image}';`}
            alt={s.alt}
            loading="lazy"
            decoding="async"
          />
          <div class="tile-overlay">
            <span class="tile-title">{s.title}</span>
          </div>
        </a>
      ))}
    </div>

    <!-- Sleep Apnea sidebar -->
    <aside class="sleep-apnea-sidebar">
      <div class="sidebar-inner">
        <p class="sidebar-kicker">Sleep Apnea</p>
        <h3>Do You Suffer From Sleep Apnea?</h3>
        <p>{sleepApnea.body}</p>
        <a href={sleepApnea.cta.href} class="btn-sidebar">LEARN MORE ABOUT SLEEP APNEA</a>
      </div>
    </aside>
  </div>
</section>

<style>
  .services-section { background: #fff; }

  .services-wrap {
    display: grid;
    grid-template-columns: 1fr 320px;
    max-width: var(--container-width);
    margin: 0 auto;
  }

  /* 2×2 grid */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }

  .service-tile {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    color: #fff;
  }
  .service-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .service-tile:hover img { transform: scale(1.06); }

  .tile-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    transition: background 0.3s;
  }
  .service-tile:hover .tile-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.25) 60%, transparent 100%);
  }
  .tile-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
  }

  /* Sidebar */
  .sleep-apnea-sidebar {
    background: var(--color-accent);
    display: flex;
    align-items: stretch;
  }
  .sidebar-inner {
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }
  .sidebar-kicker {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-text-main);
  }
  .sidebar-inner h3 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.25;
  }
  .sidebar-inner p {
    font-size: 0.9rem;
    color: var(--color-text-main);
    line-height: 1.7;
  }
  .btn-sidebar {
    display: inline-block;
    align-self: flex-start;
    background: var(--color-accent-hover);
    color: #333333;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.65rem 1.5rem;
    border-radius: 4px;
    margin-top: 0.5rem;
    transition: background 0.2s;
  }
  .btn-sidebar:hover { background: #5fa2a7; }

  @media (max-width: 900px) {
    .services-wrap { grid-template-columns: 1fr; }
    .sleep-apnea-sidebar { order: -1; }
    .sidebar-inner { padding: 2rem; }
  }
  @media (max-width: 600px) {
    .services-grid { grid-template-columns: 1fr; }
    .service-tile { aspect-ratio: 16 / 9; }
  }
</style>
