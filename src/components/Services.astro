---
const services = [
  { title: "DENTAL EXAMS", icon: "🔍" },
  { title: "TOOTH PAIN", icon: "🦷" },
  { title: "DENTAL CLEANINGS", icon: "🧼" },
  { title: "COSMETIC DENTISTRY", icon: "✨" }
];
---
<section id="services" class="services section">
  <div class="container">
    <div class="section-header">
      <h2>DENTIST BELLEVUE WA</h2>
      <p>Luxury care meets clinical excellence. Discover our boutique approach to your oral health.</p>
    </div>
    
    <div class="service-grid">
      {services.map(service => (
        <div class="service-card">
          <div class="service-icon">{service.icon}</div>
          <h3>{service.title}</h3>
          <a href="#" class="btn-outline-small">View Service</a>
        </div>
      ))}
    </div>

    <!-- Niche Specialties (Sleep Apnea & TMJ) -->
    <div class="specialties-grid">
      <div class="specialty-card">
        <h3>SLEEP APNEA</h3>
        <p>Do you wake up feeling tired? We provide dental solutions for sleep apnea and snoring.</p>
        <a href="#">Learn About Sleep Apnea →</a>
      </div>
      <div class="specialty-card">
        <h3>TMJ THERAPY</h3>
        <p>Relieve jaw pain and headaches with our advanced neuromuscular dentistry treatments.</p>
        <a href="#">Explore TMJ Solutions →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .section { padding: 6rem 0; }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-header h2 { font-size: 0.875rem; letter-spacing: 0.3em; color: var(--color-gold); margin-bottom: 1rem; }
  .section-header p { font-size: 2rem; max-width: 800px; margin: 0 auto; line-height: 1.3; }
  
  .service-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }
  .service-card {
    background: white;
    padding: 3rem 1.5rem;
    border: 1px solid var(--color-border);
    text-align: center;
    transition: all 0.3s ease;
  }
  .service-card:hover { border-color: var(--color-gold); box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
  .service-icon { font-size: 2rem; margin-bottom: 1.5rem; }
  .service-card h3 { font-size: 1rem; letter-spacing: 0.1em; margin-bottom: 1.5rem; }
  
  .specialties-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .specialty-card {
    background: var(--color-bg-warm);
    padding: 4rem;
    border-radius: 4px;
  }
  .specialty-card h3 { font-size: 1.5rem; letter-spacing: 0.1em; margin-bottom: 1rem; }
  .specialty-card p { margin-bottom: 2rem; color: var(--color-text-muted); }
  .specialty-card a { color: var(--color-gold); font-weight: 700; text-decoration: none; }

  .btn-outline-small {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--color-gold);
    color: var(--color-gold);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
  }
  
  @media (max-width: 992px) {
    .service-grid { grid-template-columns: repeat(2, 1fr); }
    .specialties-grid { grid-template-columns: 1fr; }
  }
</style>
