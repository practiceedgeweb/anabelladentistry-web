---
import home from '../data/pages/home.json';
const services = home.services;
---
<section id="services" class="services section">
  <div class="container">
    <div class="section-header">
      <span class="sub-label">Our Services</span>
      <h2>Comprehensive Dental Care, Bellevue WA</h2>
    </div>
    <div class="grid">
      {services.map((s) => (
        <a class="card" href={s.href}>
          <div class="img-wrap">
            <img
              src={`/assets/2025/10/${s.image.split('/').pop()}`}
              onerror={`this.onerror=null;this.src='${s.image}';`}
              alt={s.alt}
              loading="lazy"
              decoding="async"
              width="600"
              height="400"
            />
          </div>
          <h3>{s.title}</h3>
          <span class="arrow">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services { background: #fff; }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-header h2 { font-size: 2rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: all 0.2s ease;
  }
  .card:hover {
    border-color: var(--color-accent-hover);
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08);
  }
  .img-wrap {
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }
  .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .card:hover .img-wrap img { transform: scale(1.05); }
  .card h3 {
    margin: 1rem 1.25rem 0.25rem;
    font-size: 1.15rem;
  }
  .arrow {
    margin: 0 1.25rem 1.25rem;
    color: var(--color-accent-hover);
    font-size: 0.85rem;
    font-weight: 700;
  }

  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .grid { grid-template-columns: 1fr; } }
</style>
