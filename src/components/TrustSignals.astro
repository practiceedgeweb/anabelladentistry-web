---
// Trust bar — replaces Gemini's fabricated "Voted Best of Seattle" / "Diamond Provider"
// claims with facts taken verbatim from the live site.
import site from '../data/site.json';
import home from '../data/pages/home.json';
---
<section class="trust">
  <div class="container inner">
    <div class="cell">
      <span class="kicker">{home.scheduleBar.label}</span>
      <p>{home.scheduleBar.body}</p>
      <a href={home.scheduleBar.cta.href} class="btn-primary">{home.scheduleBar.cta.text}</a>
    </div>
    <div class="divider" aria-hidden="true"></div>
    <div class="cell right">
      <ul>
        <li><strong>30+ years</strong> serving Bellevue</li>
        <li><strong>Most major</strong> dental insurances accepted</li>
        <li><strong>Comfort amenities:</strong> sedation, Netflix, blankets</li>
      </ul>
      <a href={`tel:${site.contact.phoneTel}`} class="phone">{site.contact.phone}</a>
    </div>
  </div>
</section>

<style>
  .trust {
    background: var(--color-accent-wave);
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    align-items: center;
  }
  .cell { display: flex; flex-direction: column; gap: 1rem; }
  .right { text-align: right; align-items: flex-end; }
  .kicker {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-accent-hover);
    font-weight: 700;
  }
  ul { list-style: none; }
  ul li { margin-bottom: 0.35rem; color: var(--color-text-main); }
  .phone {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent-hover);
  }
  .divider { width: 1px; height: 60px; background: var(--color-border); }

  @media (max-width: 800px) {
    .inner { grid-template-columns: 1fr; text-align: left; }
    .right { align-items: flex-start; text-align: left; }
    .divider { display: none; }
  }
</style>
