---
import site from '../data/site.json';
---
<section class="trust">
  <div class="trust-inner">
    <div class="trust-text">
      <h2>You Deserve A<br>Beautiful Smile</h2>
      <p>You'll know the moment you arrive that this is the place. We are here to exceed your expectations and provide comfort and care for the whole family.</p>
    </div>
    <div class="trust-schedule">
      <h3>Schedule TODAY</h3>
      <p>Call us or book online — same-day appointments often available.</p>
      <a href="/schedule/" class="btn-schedule-dark">MAKE APPOINTMENT</a>
      <a href={`tel:${site.contact.phoneTel}`} class="trust-phone">{site.contact.phone}</a>
    </div>
  </div>
</section>

<style>
  .trust { background: #fff; }
  .trust-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 280px;
  }
  .trust-text {
    padding: 3.5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: #fff;
  }
  .trust-text h2 {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }
  .trust-text p {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 420px;
    line-height: 1.7;
  }

  .trust-schedule {
    background: #5c4a3a;
    padding: 3.5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    color: #fff;
  }
  .trust-schedule h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .trust-schedule p {
    color: rgba(255,255,255,0.8);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }
  .btn-schedule-dark {
    display: inline-block;
    align-self: flex-start;
    background: var(--color-accent-hover);
    color: #333333;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    transition: background 0.2s;
  }
  .btn-schedule-dark:hover { background: #5fa2a7; }

  .trust-phone {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    margin-top: 0.25rem;
  }
  .trust-phone:hover { color: #fff; }

  @media (max-width: 800px) {
    .trust-inner { grid-template-columns: 1fr; }
    .trust-text, .trust-schedule { padding: 2.5rem 2rem; }
    .trust-text h2 { font-size: 1.75rem; }
  }
</style>
