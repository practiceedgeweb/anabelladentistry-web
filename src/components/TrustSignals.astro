<section class="trust-signals">
  <div class="container signals-inner">
    <div class="signal">
      <span class="signal-icon">🏆</span>
      <div class="signal-text">
        <strong>Voted Best of Seattle</strong>
        <span>10+ Consecutive Years</span>
      </div>
    </div>
    <div class="signal">
      <span class="signal-icon">💎</span>
      <div class="signal-text">
        <strong>Diamond Provider</strong>
        <span>CandidPro Clear Aligners</span>
      </div>
    </div>
    <div class="signal">
      <span class="signal-icon">👩‍⚕️</span>
      <div class="signal-text">
        <strong>30+ Years Experience</strong>
        <span>Expert Clinical Care</span>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-signals {
    padding: 3rem 0;
    background: var(--color-bg-warm);
    border-bottom: 1px solid var(--color-border);
  }
  .signals-inner {
    display: flex;
    justify-content: space-around;
    align-items: center;
    gap: 2rem;
  }
  .signal {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .signal-icon {
    font-size: 2rem;
  }
  .signal-text {
    display: flex;
    flex-direction: column;
  }
  .signal-text strong {
    font-size: 1.125rem;
    color: var(--color-text-main);
  }
  .signal-text span {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  
  @media (max-width: 768px) {
    .signals-inner { flex-direction: column; text-align: center; }
  }
</style>
