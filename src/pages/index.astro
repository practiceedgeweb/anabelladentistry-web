---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustSignals from '../components/TrustSignals.astro';
import Services from '../components/Services.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import home from '../data/pages/home.json';
---

<Layout
  title={home.meta.title}
  description={home.meta.description}
  canonical={home.meta.canonical}
  ogImage={home.meta.ogImage}
>
  <Header />

  <main>
    <Hero />
    <TrustSignals />
    <Services />

    <section class="intro-bio section">
      <div class="container bio">
        <div class="bio-text">
          <span class="sub-label">{home.sleepApnea.heading}</span>
          <h2>Breathe Better. Sleep Better.</h2>
          <p>{home.sleepApnea.body}</p>
          <a href={home.sleepApnea.cta.href} class="btn-primary">{home.sleepApnea.cta.text}</a>
        </div>
        <div class="bio-image">
          <img
            src="/assets/external/dental-snoring.webp"
            onerror="this.onerror=null;this.src='http://www.dental.inceptionimages.com/wp-content/uploads/2024/12/Dentist-Learning-New-Technique-At-A-School-Leaf-D.webp';"
            alt="Sleep apnea treatment"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>
    </section>

    <section class="insurance section">
      <div class="container text-center">
        <span class="sub-label">Insurance</span>
        <h2>{home.insurance.heading}</h2>
        <p>{home.insurance.body}</p>
      </div>
    </section>

    <section class="history section">
      <div class="container text-center narrow">
        <span class="sub-label">Our History</span>
        <h2>{home.practiceHistory.heading}</h2>
        <p>{home.practiceHistory.body}</p>
      </div>
    </section>

    <section class="comfort section">
      <div class="container text-center narrow">
        <span class="sub-label">Comfort First</span>
        <h2>{home.comfort.heading}</h2>
        <p>{home.comfort.body}</p>
      </div>
    </section>

    <section class="tmj section">
      <div class="container bio reverse">
        <div class="bio-text">
          <span class="sub-label">{home.tmj.heading}</span>
          <h2>Relief From Jaw Pain &amp; Headaches</h2>
          <p>{home.tmj.body}</p>
          <a href={home.tmj.cta.href} class="btn-primary">{home.tmj.cta.text}</a>
        </div>
      </div>
    </section>

    <Testimonials />

    <section class="final-cta section">
      <div class="container text-center">
        <p class="prefix">{home.finalCta.prefix}</p>
        <h2>{home.finalCta.title}</h2>
        <a href={home.finalCta.cta.href} class="btn-primary">{home.finalCta.cta.text}</a>
      </div>
    </section>

    <Contact />
  </main>

  <Footer />
</Layout>

<style>
  .text-center { text-align: center; }
  .narrow { max-width: 760px; margin: 0 auto; }

  .intro-bio, .tmj { background: #fff; }
  .bio {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .bio.reverse .bio-text { grid-column: 1; }
  .bio h2 { font-size: 2rem; margin-bottom: 1rem; }
  .bio-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  .insurance { background: var(--color-bg-warm); }
  .insurance h2 { font-size: 1.5rem; }
  .history { background: #fff; }
  .comfort { background: var(--color-accent-wave); }

  .final-cta { background: var(--color-accent-hover); color: #fff; text-align: center; }
  .final-cta h2 { color: #fff; font-size: 2.25rem; margin-bottom: 1.5rem; }
  .final-cta .prefix {
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0.75rem;
  }
  .final-cta .btn-primary {
    background: #fff;
    color: var(--color-accent-hover);
  }
  .final-cta .btn-primary:hover { background: var(--color-text-main); color: #fff; }

  @media (max-width: 900px) {
    .bio { grid-template-columns: 1fr; }
  }
</style>
