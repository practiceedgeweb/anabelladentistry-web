---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustSignals from '../components/TrustSignals.astro';
import Services from '../components/Services.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
import home from '../data/pages/home.json';
import site from '../data/site.json';
---

<Layout
  title={home.meta.title}
  description={home.meta.description}
  canonical={home.meta.canonical}
  ogImage={home.meta.ogImage}
>
  <Header />

  <main>
    <Hero />

    <!-- Doctor Bio -->
    <section class="doctor-bio">
      <div class="bio-grid">
        <div class="bio-img-wrap">
          <img
            src={`/assets/2025/10/${home.hero.image.src.split('/').pop()}`}
            onerror={`this.onerror=null;this.src='${home.hero.image.src}';`}
            alt={home.hero.image.alt}
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="bio-card">
          <span class="bio-kicker">Dentist Bellevue WA</span>
          <h2>Welcome to AnaBella Family and Cosmetic Dentistry</h2>
          <p>{home.hero.body}</p>
          <p class="bio-secondary">{home.hero.secondaryBody}</p>
          <a href={home.hero.secondaryCta.href} class="btn-meet">MEET THE DOCTOR</a>
        </div>
      </div>
    </section>

    <TrustSignals />

    <Services />

    <!-- Insurance -->
    <section class="insurance-bar">
      <div class="container insurance-inner">
        <div class="insurance-text">
          <h2>{home.insurance.heading}</h2>
          <p>{home.insurance.body}</p>
        </div>
        <a href="/dental-insurance-accepted/" class="btn-insurance">VIEW INSURANCES</a>
      </div>
    </section>

    <!-- Practice History + Comfort (dark brown bg) -->
    <section class="history-comfort">
      <div class="container hc-grid">
        <div class="hc-col">
          <span class="hc-kicker">Our History</span>
          <h2>{home.practiceHistory.heading}</h2>
          <p>{home.practiceHistory.body}</p>
        </div>
        <div class="hc-divider" aria-hidden="true"></div>
        <div class="hc-col">
          <span class="hc-kicker">Comfort First</span>
          <h2>{home.comfort.heading}</h2>
          <p>{home.comfort.body}</p>
        </div>
      </div>
    </section>

    <!-- TMJ Section -->
    <section class="tmj-section">
      <div class="tmj-grid">
        <div class="tmj-img">
          <img
            src="/assets/2025/10/Dentist-Bellevue-WA-TMJ.webp"
            onerror="this.onerror=null;this.src='https://www.anabelladentistry.com/wp-content/uploads/2025/10/Dentist-Bellevue-WA-TMJ.webp';"
            alt="TMJ treatment at AnaBella Family and Cosmetic Dentistry"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="tmj-card">
          <span class="bio-kicker">TMJ Therapy</span>
          <h2>Relief From Jaw Pain &amp; Headaches</h2>
          <p>{home.tmj.body}</p>
          <a href={home.tmj.cta.href} class="btn-meet">LEARN MORE</a>
        </div>
      </div>
    </section>

    <Testimonials />
  </main>

  <Footer />
</Layout>

<style>
  /* Doctor Bio */
  .doctor-bio { background: #fff; }
  .bio-grid {
    display: grid;
    grid-template-columns: 420px 1fr;
    min-height: 500px;
    max-width: var(--container-width);
    margin: 0 auto;
  }
  .bio-img-wrap { overflow: hidden; }
  .bio-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .bio-card {
    background: var(--color-accent);
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }
  .bio-kicker {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-accent-hover);
  }
  .bio-card h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.25;
  }
  .bio-card p {
    font-size: 0.95rem;
    color: var(--color-text-main);
    line-height: 1.75;
  }
  .bio-secondary { font-style: italic; opacity: 0.85; }
  .btn-meet {
    display: inline-block;
    align-self: flex-start;
    background: var(--color-accent-hover);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    margin-top: 0.5rem;
    transition: background 0.2s;
  }
  .btn-meet:hover { background: #5fa2a7; }

  /* Insurance bar */
  .insurance-bar { background: var(--color-bg-warm); padding: 3rem 0; }
  .insurance-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .insurance-text h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-main);
  }
  .insurance-text p { color: var(--color-text-muted); font-size: 0.95rem; }
  .btn-insurance {
    display: inline-block;
    background: var(--color-accent-hover);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .btn-insurance:hover { background: #5fa2a7; }

  /* History + Comfort — dark brown */
  .history-comfort {
    background: #5c4a3a;
    padding: 5rem 0;
  }
  .hc-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 3rem;
    align-items: start;
  }
  .hc-col { color: rgba(255,255,255,0.9); }
  .hc-kicker {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .hc-col h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .hc-col p {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.8);
  }
  .hc-divider {
    width: 1px;
    background: rgba(255,255,255,0.15);
    align-self: stretch;
    margin: 1rem 0;
  }

  /* TMJ section */
  .tmj-section { background: #fff; }
  .tmj-grid {
    display: grid;
    grid-template-columns: 1fr 480px;
    max-width: var(--container-width);
    margin: 0 auto;
    min-height: 400px;
  }
  .tmj-img { overflow: hidden; }
  .tmj-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tmj-card {
    background: var(--color-accent-wave);
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }
  .tmj-card h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-main);
    line-height: 1.25;
  }
  .tmj-card p {
    font-size: 0.95rem;
    color: var(--color-text-main);
    line-height: 1.75;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .bio-grid { grid-template-columns: 1fr; }
    .bio-img-wrap { max-height: 320px; }
    .tmj-grid { grid-template-columns: 1fr; }
    .tmj-img { max-height: 260px; }
    .hc-grid { grid-template-columns: 1fr; }
    .hc-divider { display: none; }
  }
</style>
