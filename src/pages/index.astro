---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustSignals from '../components/TrustSignals.astro';
import Services from '../components/Services.astro';
---

<Layout title="AnaBella Family & Cosmetic Dentistry | Bellevue WA">
	<main>
		<Header />
		<Hero />
		<TrustSignals />
		
		<section class="intro-bio section">
			<div class="container bio-inner">
				<div class="bio-text">
					<span class="sub-label">ABOUT OUR PRACTICE</span>
					<h2>A NEW STANDARD OF DENTAL CARE</h2>
					<p>Dr. Clara H. Song has been providing world-class dentistry for over three decades. Our practice combines advanced laser technology with a warm, boutique environment to ensure your visit is comfortable, fun, and effective.</p>
					<a href="#" class="btn-gold">Meet The Doctor</a>
				</div>
				<div class="bio-image">
					<img src="https://images.unsplash.com/photo-1559839734-2b71f1e598c6?auto=format&fit=crop&q=80&w=800" alt="Dr. Clara H. Song" />
				</div>
			</div>
		</section>

		<Services />
		
		<section class="insurance section">
			<div class="container text-center">
				<h2>WE WORK WITH YOUR INSURANCE</h2>
				<p>AnaBella Dentistry is a preferred provider for most major dental insurance plans. We make the process simple so you can focus on your smile.</p>
			</div>
		</section>

		<section class="cta-final section">
			<div class="container text-center">
				<h2>READY TO FIND OUT MORE?</h2>
				<p>Experience the AnaBella difference today. New patients are always welcome.</p>
				<a href="#" class="btn-gold">Schedule Your Consultation</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	.text-center { text-align: center; }
	.section { padding: 8rem 0; }
	.sub-label { font-size: 0.75rem; letter-spacing: 0.3em; color: var(--color-gold); font-weight: 700; margin-bottom: 1rem; display: block; }
	
	.intro-bio { background: white; }
	.bio-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
	.bio-text h2 { font-size: 2.5rem; margin-bottom: 2rem; }
	.bio-text p { font-size: 1.125rem; margin-bottom: 2.5rem; }
	.bio-image img { width: 100%; border-radius: 8px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); }

	.insurance { background: var(--color-bg-warm); border-top: 1px solid var(--color-border); }
	.insurance h2 { font-size: 1.5rem; letter-spacing: 0.1em; margin-bottom: 1rem; }

	.cta-final { background: white; border-top: 1px solid var(--color-border); }
	.cta-final h2 { font-size: 2.5rem; margin-bottom: 1.5rem; }

	@media (max-width: 992px) {
		.bio-inner { grid-template-columns: 1fr; text-align: center; }
		.section { padding: 4rem 0; }
	}
</style>
