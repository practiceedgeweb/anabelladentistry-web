---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const meta = {
  title: "Office Tour - AnaBella Family and Cosmetic Dentistry",
  description: "Take a virtual tour of AnaBella Family and Cosmetic Dentistry in Bellevue WA. See our welcoming, modern dental office.",
  canonical: "https://www.anabelladentistry.com/office-tour/",
};

const images = [
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Front-Desk.webp",                  alt: "Front desk at AnaBella Dentistry" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Lobby.webp",                        alt: "Lobby at AnaBella Dentistry" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Waiting-Area.webp",                 alt: "Waiting area" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Front-of-Office.webp",              alt: "Front of office" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Hallway-and-Treatment-Room.webp",   alt: "Hallway and treatment room" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Hallway.webp",                      alt: "Office hallway" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Treatment-Room.webp",               alt: "Treatment room" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Treatment-Area.webp",               alt: "Treatment area" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Treatment-and-Exam-Room.webp",      alt: "Treatment and exam room" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Exam-Room.webp",                    alt: "Exam room" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Exam-Area.webp",                    alt: "Exam area" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Dental-Exam-Chair.webp",            alt: "Dental exam chair" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Diagnostic-Tools.webp",             alt: "Diagnostic tools" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-X-Ray.webp",                        alt: "X-ray area" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Break-Room.webp",                   alt: "Break room" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Kitchen.webp",                      alt: "Kitchen" },
  { src: "/assets/2025/10/Dentist-Bellevue-WA-Office-Kitchen.webp",               alt: "Office kitchen" },
];
---

<Layout title={meta.title} description={meta.description} canonical={meta.canonical}>
  <Header />
  <main class="office-tour-page">
    <div class="container">
      <h1>AnaBella Family And Cosmetic Dentistry Office Tour</h1>
    </div>

    <!-- Carousel -->
    <div class="carousel-wrap">
      <button class="carousel-btn prev" id="prevBtn" aria-label="Previous photos">&#8249;</button>

      <div class="carousel-track-wrap">
        <div class="carousel-track" id="carouselTrack">
          {images.map((img) => (
            <div class="carousel-slide">
              <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
            </div>
          ))}
        </div>
      </div>

      <button class="carousel-btn next" id="nextBtn" aria-label="Next photos">&#8250;</button>
    </div>

    <!-- Tagline -->
    <div class="tour-tagline">
      <p>We are committed to creating smiles from the inside out.</p>
      <p><a href="/contact-us/">Contact us</a> today for more information.</p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .office-tour-page { padding: 3rem 0 0; }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-main);
    text-align: center;
    margin-bottom: 2rem;
  }

  /* Carousel */
  .carousel-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
    max-width: 1400px;
    margin: 0 auto 2.5rem;
    padding: 0 3rem;
  }

  .carousel-track-wrap {
    flex: 1;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.4s ease;
  }

  .carousel-slide {
    flex: 0 0 calc(100% / 3);
    padding: 0 0.5rem;
    box-sizing: border-box;
  }

  .carousel-slide img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
  }

  /* Arrow buttons */
  .carousel-btn {
    width: 44px;
    height: 44px;
    background: var(--color-accent);
    border: none;
    cursor: pointer;
    font-size: 1.75rem;
    line-height: 1;
    color: var(--color-text-main);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s;
    z-index: 1;
  }
  .carousel-btn:hover { background: var(--color-accent-hover); color: #fff; }

  /* Tagline */
  .tour-tagline {
    text-align: center;
    padding: 2rem 1rem 4rem;
    font-size: 1rem;
    color: var(--color-text-main);
    line-height: 1.9;
  }
  .tour-tagline a {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 700px) {
    .carousel-slide { flex: 0 0 100%; }
    .carousel-wrap { padding: 0 1rem; }
  }
</style>

<script>
  const track = document.getElementById('carouselTrack') as HTMLElement;
  const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement;
  const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;

  const total = track.children.length;
  const visible = window.innerWidth <= 700 ? 1 : 3;
  let current = 0;

  function maxIndex() {
    return total - (window.innerWidth <= 700 ? 1 : 3);
  }

  function move() {
    const pct = (100 / (window.innerWidth <= 700 ? 1 : 3)) * current;
    track.style.transform = `translateX(-${pct}%)`;
  }

  prevBtn.addEventListener('click', () => {
    current = current <= 0 ? maxIndex() : current - 1;
    move();
  });

  nextBtn.addEventListener('click', () => {
    current = current >= maxIndex() ? 0 : current + 1;
    move();
  });
</script>
