---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';

const meta = {
  title: "Schedule Appointment Today - AnaBella Family and Cosmetic Dentistry",
  description: "Schedule your appointment for the best dental care in Bellevue WA at AnaBella Family and Cosmetic Dentistry today. Your smile is our priority!",
  canonical: "https://www.anabelladentistry.com/schedule/",
};

const zocdoc = "https://www.zocdoc.com/practice/anabella-family-and-cosmetic-dentistry-12212?lock=true&isNewPatient=false&referrerType=widget";
---

<Layout title={meta.title} description={meta.description} canonical={meta.canonical}>
  <Header />
  <main class="interior-page schedule-page">
    <div class="container interior-grid">
      <div class="interior-content">
        <h1>Schedule Your Appointment Today</h1>

        <img
          class="schedule-hero"
          src="/assets/2024/11/Happy-Smiling-Couple-At-Home-CS1.webp"
          alt="Happy couple smiling at home — AnaBella Family and Cosmetic Dentistry patients"
          loading="eager"
          decoding="async"
        />

        <p class="schedule-intro">
          Ready to take the next step toward a healthier smile? At AnaBella Family and Cosmetic Dentistry,
          we make scheduling an appointment simple and stress-free. Our friendly team is here to help you
          find a convenient time for your visit, answer any questions, and ensure you're well-prepared for
          your appointment. Whether you're coming in for a routine cleaning or need a specific treatment,
          we're excited to meet you and support your dental health journey!
        </p>

        <div class="schedule-cta-wrap">
          <a href={zocdoc} class="btn-schedule-cta" target="_blank" rel="noopener noreferrer">
            CLICK HERE TO SCHEDULE ONLINE
          </a>
        </div>
      </div>
      <Sidebar />
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .schedule-hero {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 1.75rem;
    border-radius: 0;
  }

  .schedule-intro {
    font-size: 1rem;
    line-height: 1.85;
    color: var(--color-text-main);
    text-align: center;
    margin-bottom: 2rem;
  }

  .schedule-cta-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .btn-schedule-cta {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-text-main);
    padding: 1rem 2.5rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 4px;
    transition: background 0.2s, color 0.2s;
  }
  .btn-schedule-cta:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }
</style>
