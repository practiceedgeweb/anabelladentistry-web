---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const meta = {
  title: "Smile Gallery - AnaBella Family and Cosmetic Dentistry",
  description: "Take a look at the outstanding patient results from AnaBella Family and Cosmetic Dentistry in Bellevue WA.",
  canonical: "https://www.anabelladentistry.com/smile-gallery/",
};

const BASE = "/assets/2025/10";

// Each image is a pre-composed composite (portrait left + before/after right)
const slides = [
  { src: `${BASE}/Dentist-Bellevue-WA-Teeth-Whitening.webp`,        alt: "Patient smile transformation — teeth whitening result" },
  { src: `${BASE}/Dentist-Bellevue-WA-White-Teeth.webp`,            alt: "Patient smile transformation — white teeth result" },
  { src: `${BASE}/Dentist-Bellevue-WA-Bride.webp`,                  alt: "Bride smile transformation result" },
  { src: `${BASE}/Dentist-Bellevue-WA-Veneers.webp`,                alt: "Patient smile transformation — veneers result" },
  { src: `${BASE}/Dentist-Bellevue-WA-Even-Teeth.webp`,             alt: "Patient smile transformation — even teeth result" },
  { src: `${BASE}/Dentist-Bellevue-WA-Straighter-Whiter-Teeth.webp`, alt: "Patient smile transformation — straighter whiter teeth" },
];
---

<Layout title={meta.title} description={meta.description} canonical={meta.canonical}>
  <Header />
  <main class="gallery-page">
    <div class="container">
      <h1>AnaBella Family And Cosmetic Dentistry Smile Gallery</h1>
    </div>

    <!-- Carousel -->
    <div class="gallery-carousel">
      <button class="gallery-btn prev" id="prevBtn" aria-label="Previous">&#8249;</button>

      <div class="slides-wrap">
        <div class="slides-track" id="slidesTrack">
          {slides.map((slide, i) => (
            <div class="gallery-slide">
              <img
                src={slide.src}
                alt={slide.alt}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
          ))}
        </div>
      </div>

      <button class="gallery-btn next" id="nextBtn" aria-label="Next">&#8250;</button>
    </div>

    <!-- Caption -->
    <div class="gallery-caption">
      <p>They say that a picture is worth a thousand words. Our photos speak for themselves.</p>
      <p>If you are wondering how a visit to <a href="/">AnaBella Family and Cosmetic Dentistry</a> can improve your smile and your life, take a minute to look through our photo gallery.</p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .gallery-page { padding: 3rem 0 0; }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-main);
    text-align: center;
    margin-bottom: 2rem;
  }

  .gallery-carousel {
    display: flex;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto 2.5rem;
    padding: 0 1rem;
    gap: 0.5rem;
  }

  .slides-wrap {
    flex: 1;
    overflow: hidden;
    min-width: 0;
  }

  .slides-track {
    display: flex;
    width: 100%;
    transition: transform 0.4s ease;
  }

  .gallery-slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  .gallery-slide img {
    width: 100%;
    height: auto;
    display: block;
  }

  .gallery-btn {
    background: var(--color-accent);
    border: none;
    cursor: pointer;
    font-size: 2rem;
    line-height: 1;
    color: var(--color-text-main);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s, color 0.2s;
  }
  .gallery-btn:hover { background: var(--color-accent-hover); color: #fff; }

  .gallery-caption {
    text-align: center;
    padding: 1.5rem 2rem 4rem;
    font-size: 1rem;
    color: var(--color-text-main);
    line-height: 2;
  }
  .gallery-caption a {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 700px) {
    .gallery-btn { width: 36px; font-size: 1.5rem; }
  }
</style>

<script>
  const track = document.getElementById('slidesTrack') as HTMLElement;
  const total = track.children.length;
  let current = 0;

  function show(idx: number) {
    current = (idx + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
  }

  document.getElementById('prevBtn')!.addEventListener('click', () => show(current - 1));
  document.getElementById('nextBtn')!.addEventListener('click', () => show(current + 1));
</script>
