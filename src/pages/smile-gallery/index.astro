---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const meta = {
  title: "Smile Gallery - AnaBella Family and Cosmetic Dentistry",
  description: "Take a look at the outstanding patient results from AnaBella Family and Cosmetic Dentistry in Bellevue WA.",
  canonical: "https://www.anabelladentistry.com/smile-gallery/",
};

const BASE = "/assets/2025/10";

const slides = [
  {
    portrait: { src: `${BASE}/Dentist-Bellevue-WA-Bride.webp`,                   alt: "Patient smile result" },
    before:   { src: `${BASE}/Dentist-Bellevue-WA-Broken-Teeth.webp`,             alt: "Before dental treatment" },
    after:    { src: `${BASE}/Dentist-Bellevue-WA-White-Teeth.webp`,              alt: "After dental treatment" },
  },
  {
    portrait: { src: `${BASE}/Dentist-Bellevue-WA-Veneers.webp`,                  alt: "Veneers result" },
    before:   { src: `${BASE}/Dentist-Bellevue-WA-Teeth-Whitening.webp`,          alt: "Before teeth whitening" },
    after:    { src: `${BASE}/Dentist-Bellevue-WA-Straighter-Whiter-Teeth.webp`,  alt: "After teeth whitening" },
  },
  {
    portrait: { src: `${BASE}/Dentist-Bellevue-WA-Even-Teeth.webp`,               alt: "Even teeth result" },
    before:   { src: `${BASE}/Dentist-Bellevue-WA-Tooth-and-Gum-Restoration.webp`, alt: "Before gum restoration" },
    after:    { src: `${BASE}/Dentist-Bellevue-WA-Straighter-Whiter-Teeth.webp`,  alt: "After gum restoration" },
  },
];
---

<Layout title={meta.title} description={meta.description} canonical={meta.canonical}>
  <Header />
  <main class="gallery-page">
    <div class="container">
      <h1>AnaBella Family And Cosmetic Dentistry Smile Gallery</h1>
    </div>

    <!-- Carousel -->
    <div class="gallery-carousel">
      <button class="gallery-btn prev" id="prevBtn" aria-label="Previous">&#8249;</button>

      <div class="slides-wrap">
        {slides.map((slide, i) => (
          <div class={`gallery-slide${i === 0 ? ' active' : ''}`} data-index={i}>
            <div class="slide-inner">
              <div class="slide-portrait">
                <img src={slide.portrait.src} alt={slide.portrait.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
              </div>
              <div class="slide-before-after">
                <img src={slide.before.src} alt={slide.before.alt} loading="lazy" decoding="async" />
                <img src={slide.after.src}  alt={slide.after.alt}  loading="lazy" decoding="async" />
              </div>
            </div>
          </div>
        ))}
      </div>

      <button class="gallery-btn next" id="nextBtn" aria-label="Next">&#8250;</button>
    </div>

    <!-- Caption -->
    <div class="gallery-caption">
      <p>They say that a picture is worth a thousand words. Our photos speak for themselves.</p>
      <p>If you are wondering how a visit to <a href="/">AnaBella Family and Cosmetic Dentistry</a> can improve your smile and your life, take a minute to look through our photo gallery.</p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .gallery-page { padding: 3rem 0 0; }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-main);
    text-align: center;
    margin-bottom: 2rem;
  }

  /* Carousel shell */
  .gallery-carousel {
    display: flex;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto 2.5rem;
    padding: 0 1rem;
    gap: 0.5rem;
  }

  .slides-wrap {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  /* Slides */
  .gallery-slide {
    display: none;
  }
  .gallery-slide.active {
    display: block;
  }

  .slide-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }

  .slide-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .slide-before-after {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .slide-before-after img {
    width: 100%;
    height: calc(50% - 3px);
    object-fit: cover;
    display: block;
    flex: 1;
  }

  /* Arrow buttons */
  .gallery-btn {
    background: var(--color-accent);
    border: none;
    cursor: pointer;
    font-size: 2rem;
    line-height: 1;
    color: var(--color-text-main);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s, color 0.2s;
  }
  .gallery-btn:hover { background: var(--color-accent-hover); color: #fff; }

  /* Caption */
  .gallery-caption {
    text-align: center;
    padding: 1.5rem 2rem 4rem;
    font-size: 1rem;
    color: var(--color-text-main);
    line-height: 2;
  }
  .gallery-caption a {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 700px) {
    .slide-inner { grid-template-columns: 1fr; }
    .gallery-btn { width: 36px; font-size: 1.5rem; }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.gallery-slide');
  const total = slides.length;
  let current = 0;

  function show(idx: number) {
    slides[current].classList.remove('active');
    current = (idx + total) % total;
    slides[current].classList.add('active');
  }

  document.getElementById('prevBtn')!.addEventListener('click', () => show(current - 1));
  document.getElementById('nextBtn')!.addEventListener('click', () => show(current + 1));
</script>
