---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';

const meta = {
  title: "Testimonials - AnaBella Family and Cosmetic Dentistry",
  description: "See what others are saying about Dentist Clara H. Song D.D.S. at AnaBella Family and Cosmetic Dentistry in Bellevue WA.",
  canonical: "https://www.anabelladentistry.com/testimonials/",
};

const testimonials = [
  { quote: "Easy to make appointment. Professional doctor and friendly staff. Highly recommend this clinic.", author: "Nut L." },
  { quote: "Professional doctor. Very lovely and relaxing atmosphere.", author: "B Picha S." },
  { quote: "The facilities are top notch following the remodel, and Dr. Song has been so patient in explaining treatment options to me. I initially contacted her to replace some aged crowns for cosmetic reasons, but I've enjoyed working with her so much that I'm going to switch my primary dental care here, too.", author: "Kierstin W." },
  { quote: "I actually like going to my dentist. Highly recommend this place.", author: "Ali J." },
  { quote: "The best!", author: "Jennifer T." },
];
---

<Layout title={meta.title} description={meta.description} canonical={meta.canonical}>
  <Header />
  <main class="interior-page">
    <div class="container interior-grid">
      <div class="interior-content">
        <h1>Testimonials For AnaBella Family and Cosmetic Dentistry</h1>

        <div class="hero-img-wrap">
          <img
            src="/assets/testimonials-hero.jpg"
            alt="Patient receiving dental care at AnaBella Family and Cosmetic Dentistry"
            width="1100"
            height="320"
            loading="eager"
            decoding="async"
          />
        </div>

        <p class="intro">
          At <a href="/">AnaBella Family and Cosmetic Dentistry</a>, we are committed to creating smiles from the inside out. Regardless of what dental issues you may have, we listen to your wants and needs to determine a solution. But don't just take our word for it, see what Dr. Clara H. Song's patients have to say about our services.
        </p>

        <ul class="testimonial-list">
          {testimonials.map((t) => (
            <li class="testimonial-item">
              <p class="testimonial-quote">"{t.quote}"</p>
              <p class="testimonial-author">- {t.author}</p>
            </li>
          ))}
        </ul>
      </div>

      <Sidebar />
    </div>
  </main>
  <Footer />
</Layout>

<style>
  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin-bottom: 1.5rem;
  }

  .hero-img-wrap {
    margin-bottom: 1.75rem;
  }
  .hero-img-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  .intro {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-text-main);
    margin-bottom: 2rem;
  }
  .intro a {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .testimonial-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .testimonial-item {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .testimonial-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .testimonial-quote {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-text-main);
    margin-bottom: 0.4rem;
  }

  .testimonial-author {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text-main);
  }
</style>
