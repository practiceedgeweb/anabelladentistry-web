---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';

const meta = {
  title: "About Us - AnaBella Family and Cosmetic Dentistry",
  description: "Meet the team at AnaBella Family and Cosmetic Dentistry today. We are here to serve the people of Bellevue WA.",
  canonical: "https://www.anabelladentistry.com/us/",
};

const drSong = {
  role: "DENTIST",
  name: "Clara H. Song D.D.S.",
  photo: "/assets/2025/10/Dentist-Bellevue-WA-Clara-H.-Song-Meet-the-Team.webp",
  photoFallback: "https://www.anabelladentistry.com/wp-content/uploads/2025/10/Dentist-Bellevue-WA-Clara-H.-Song-Meet-the-Team.webp",
  shortBio: "Clara Song, DDS, is the founder of AnaBella Family and Cosmetic Dentistry. Dr. Song provides compassionate cosmetic, family, and general dentistry services to patients in Kirkland & Bellevue, Washington.",
  longBio: [
    "Dr. Song majored in music at Pacific Union College in Napa Valley, California. She then earned her Doctor of Dental Surgery from Loma Linda University School of Dentistry. She is a graduate of the prestigious Las Vegas Institute for Advanced Dental Studies — the world's premier postgraduate dental teaching center — which qualifies her as one of the most progressive cosmetic dentists in the world.",
    "She started her first practice in 2001, in Dalton, Georgia. Even in a small community, Dr. Song created a highly-respected, highly-successful dental practice, where patients came from hundreds of miles away to receive her cosmetic treatments. Through many acts of Providence, Dr. Song moved to Bellevue, Washington, in 2007. AnaBella Family and Cosmetic Dentistry-Bellevue is the practice of her dreams and the culmination of many hours of searching and planning.",
    "From the moment you enter through the doors, you will feel the warm and friendly atmosphere of AnaBella Family and Cosmetic Dentistry. It is an atmosphere that Dr. Song and the entire staff are committed to providing their patients on a consistent basis. Whether you are a patient for full-mouth cosmetic dentistry treatment, routine dental cleanings, a child seeking dental treatment, or a walk-in, you will receive the same welcome and the highest quality of care.",
    "Dr. Song devotes hundreds of hours a year to continuing education. She is committed to staying informed of the new techniques and the latest discoveries in cosmetic and biological dentistry. This ensures her patients receive the most up-to-date techniques, materials, and options for their dental treatment.",
    "Dr. Song's philosophy is built on the belief that patients trust her with their dreams of a perfect smile. To that end, she is uncompromising. AnaBella Family and Cosmetic Dentistry invites you to make an appointment for a consultation and meet Dr. Song for yourself. Her humble, caring, and professional attitude will be evident, and you will immediately see why so many patients trust their dental care to Dr. Song and AnaBella Family and Cosmetic Dentistry.",
  ],
};

const brandi = {
  name: "Brandi",
  photo: "/assets/2025/10/Dentist-Bellevue-WA-Brandi.webp",
  photoFallback: "https://www.anabelladentistry.com/wp-content/uploads/2025/10/Dentist-Bellevue-WA-Brandi.webp",
  bio: "Brandi has worked in the dental field for over fifteen years. Through the years, she has had great opportunities to expand her knowledge in the dental, TMJ, cosmetic and implantology fields. Brandi thoroughly enjoys working with the team to ensure all of our patients receive the highest level of care.",
};
---

<Layout title={meta.title} description={meta.description} canonical={meta.canonical}>
  <Header />
  <main class="interior-page">
    <div class="container interior-grid">
      <div class="interior-content">
        <h1>Meet The Team</h1>

        <!-- Dr. Song -->
        <div class="team-card">
          <div class="team-card-top">
            <img
              src={drSong.photo}
              onerror={`this.onerror=null;this.src='${drSong.photoFallback}';`}
              alt="Dr. Clara H. Song"
              class="team-photo"
              width="240"
              height="240"
              loading="lazy"
              decoding="async"
            />
            <div class="team-info">
              <p class="team-role">{drSong.role}</p>
              <h2>{drSong.name}</h2>
              <p class="team-short-bio">{drSong.shortBio}</p>
            </div>
          </div>

          <!-- CSS-only READ MORE accordion -->
          <input type="checkbox" id="read-more-song" class="read-more-toggle" />
          <label for="read-more-song" class="read-more-label">
            <span class="rm-icon" aria-hidden="true">—</span>
            READ MORE
          </label>
          <div class="read-more-body">
            {drSong.longBio.map((p) => <p>{p}</p>)}
            <img
              src="/assets/2025/10/Dentist-Bellevue-WA-Affiliations.webp"
              onerror="this.onerror=null;this.src='https://www.anabelladentistry.com/wp-content/uploads/2025/10/Dentist-Bellevue-WA-Affiliations.webp';"
              alt="American Academy of Cosmetic Dentistry, ADA, and LVI Preferred Dentist logos"
              class="affil-logos"
              loading="lazy"
              decoding="async"
              width="714"
              height="105"
            />
          </div>
        </div>

        <!-- Brandi -->
        <div class="team-card team-card-simple">
          <img
            src={brandi.photo}
            onerror={`this.onerror=null;this.src='${brandi.photoFallback}';`}
            alt="Brandi, dental team member"
            class="team-photo"
            width="240"
            height="240"
            loading="lazy"
            decoding="async"
          />
          <div class="team-info">
            <h2 class="team-name-simple">{brandi.name}</h2>
            <p class="team-short-bio">{brandi.bio}</p>
          </div>
        </div>
      </div>

      <Sidebar />
    </div>
  </main>
  <Footer />
</Layout>

<style>
  h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin-bottom: 2rem;
  }

  .team-card {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    margin-bottom: 2rem;
    overflow: hidden;
  }

  .team-card-top {
    display: flex;
    gap: 2rem;
    padding: 1.75rem;
    align-items: flex-start;
  }

  .team-card-simple {
    display: flex;
    gap: 2rem;
    padding: 1.75rem;
    align-items: flex-start;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    margin-bottom: 2rem;
  }

  .team-photo {
    width: 240px;
    height: auto;
    flex-shrink: 0;
    object-fit: cover;
    display: block;
  }

  .team-info { flex: 1; }

  .team-role {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.2rem;
  }

  .team-info h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-main);
    margin-bottom: 0.75rem;
  }

  .team-name-simple {
    font-size: 1.15rem !important;
    margin-bottom: 0.5rem !important;
  }

  .team-short-bio {
    font-size: 0.95rem;
    color: var(--color-text-main);
    line-height: 1.7;
  }

  /* CSS-only accordion */
  .read-more-toggle { display: none; }

  .read-more-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.75rem;
    border-top: 1px solid var(--color-border);
    cursor: pointer;
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    user-select: none;
    transition: background 0.15s;
  }
  .read-more-label:hover { background: #fafafa; color: var(--color-text-main); }

  .rm-icon { font-size: 1rem; line-height: 1; display: inline-block; }
  .read-more-toggle:checked + .read-more-label .rm-icon { content: '+'; transform: rotate(45deg); }

  .read-more-body {
    display: none;
    padding: 1.5rem 1.75rem 1.75rem;
    border-top: 1px solid var(--color-border);
  }
  .read-more-body p {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-text-main);
    margin-bottom: 1rem;
  }

  .read-more-toggle:checked ~ .read-more-body { display: block; }

  .affil-logos {
    display: block;
    max-width: 100%;
    height: auto;
    margin-top: 1.5rem;
  }

  @media (max-width: 700px) {
    .team-card-top,
    .team-card-simple { flex-direction: column; }
    .team-photo { width: 100%; max-width: 260px; }
  }
</style>
